# Example environment variables for automation
# Prefer storing secrets in CI/CD or platform secrets store, not in files.

# Option A: Paste full client secrets JSON (recommended for local dev only)
# Set this to the entire client_secrets JSON content from Google Cloud
GOOGLE_CLIENT_SECRETS_JSON=

# Option B: Or point to a client secrets file path (ensure path is gitignored)
GOOGLE_CLIENT_SECRET_FILE=credentials.json

# Token storage: either a file path (gitignored) or full token JSON
GOOGLE_TOKEN_FILE=token.json
GOOGLE_TOKEN_JSON=

# Google Gemini / API keys
GEMINI_API_KEY=

# Optional fallback email
EMAIL_ADDRESS=
